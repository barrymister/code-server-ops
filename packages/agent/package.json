{
  "name": "code-server-ops-agent",
  "version": "0.1.1",
  "description": "Sidecar agent for code-server-ops. REST endpoints over process and extension state, with Preview→Confirm mutations and optional bundled UI.",
  "license": "MIT",
  "author": "Barry Mister <barry.mister@gmail.com>",
  "homepage": "https://github.com/barrymister/code-server-ops#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barrymister/code-server-ops.git",
    "directory": "packages/agent"
  },
  "bugs": {
    "url": "https://github.com/barrymister/code-server-ops/issues"
  },
  "keywords": [
    "code-server",
    "vscode",
    "ops",
    "admin",
    "fastify",
    "self-hosted",
    "sidecar"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "code-server-ops-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fastify/basic-auth": "^6.0.0",
    "@fastify/static": "^8.0.0",
    "fastify": "^5.1.0",
    "pidusage": "^3.0.2",
    "prom-client": "^15.1.3",
    "systeminformation": "^5.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "@types/pidusage": "^2.0.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
